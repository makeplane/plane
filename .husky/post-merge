#!/usr/bin/env sh
# Auto re-index GitNexus knowledge graph after pull/merge.
# Skips if repo not yet initialized for gitnexus or no source files changed.

[ ! -d .gitnexus ] && exit 0
[ ! -x ./scripts/gitnexus.sh ] && exit 0

# Only re-index if code files changed (skip pure docs/config pulls)
CHANGED=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD \
  -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.mjs' '*.cjs' \
     '*.py' '*.go' '*.rs' '*.java' '*.kt' '*.swift' \
  2>/dev/null | wc -l | tr -d ' ')

[ "${CHANGED:-0}" -eq 0 ] && exit 0

echo "[gitnexus] $CHANGED source files changed in pull → re-indexing in background"
./scripts/gitnexus.sh reindex-bg
