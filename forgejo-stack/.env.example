# Forgejo stack environment.
#
# GIT_DOMAIN, MAIL_DOMAIN and TZ are inherited from the parent Plane .env via
# `--env-file ../.env --env-file .env` (see startup commands below). Do NOT
# duplicate them here.
#
# Startup (from inside forgejo-stack/):
#   mkdir -p data/forgejo data/postgres backups
#   sudo chown -R 1000:1000 data/forgejo
#   docker compose --env-file ../.env --env-file .env pull
#   docker compose --env-file ../.env --env-file .env up -d
#
# Generate secrets:
#   openssl rand -base64 48

# --- Database (separate Postgres for Forgejo) ---
POSTGRES_DB=forgejo
POSTGRES_USER=forgejo
POSTGRES_PASSWORD=replace_with_openssl_rand_base64_48
FORGEJO_DB_PASSWORD=replace_with_openssl_rand_base64_48

# --- SMTP via the local mail-stack ---
# Create the mailbox first:
#   docker exec -it dovecot doveadm pw -s SHA512-CRYPT
# Add the result to mail-stack/dovecot/users as:
#   git@<MAIL_DOMAIN>:{SHA512-CRYPT}<hash>
# Add to mail-stack/postfix/virtual-mailbox-users.tmpl as:
#   git@<MAIL_DOMAIN> <MAIL_DOMAIN>/git/
# Then: cd mail-stack && docker compose restart postfix dovecot
# Put the plaintext password used above into SMTP_PASSWORD below.
SMTP_PASSWORD=replace_with_dovecot_user_password

# --- Filesystem ownership of ./data/forgejo on the host ---
USER_UID=1000
USER_GID=1000
