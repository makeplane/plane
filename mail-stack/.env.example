# Apex domain for mail (example: gizmostudio.ru).
# Postfix will identify itself as mail.${MAIL_DOMAIN}; Dovecot will store
# mailboxes under /var/mail/vhosts/${MAIL_DOMAIN}/<user>/Maildir; Rspamd
# will sign outgoing mail as d=${MAIL_DOMAIN}.
#
# IMPORTANT: must match MAIL_DOMAIN in the parent Plane .env so that the
# Let's Encrypt cert issued by Caddy matches the SMTP/IMAP TLS hostname.
MAIL_DOMAIN=gizmostudio.ru
