{
  "name": "@plane/shared-state",
  "version": "2.3.0",
  "private": true,
  "description": "Shared state shared across multiple apps internally",
  "license": "AGPL-3.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check:lint": "oxlint --type-aware -c ../../.oxlintrc.json .",
    "check:types": "tsc --noEmit",
    "check:format": "oxfmt . --check",
    "fix:lint": "oxlint --type-aware --fix -c ../../.oxlintrc.json .",
    "fix:format": "oxfmt . --write",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules && rm -rf dist"
  },
  "dependencies": {
    "@plane/constants": "workspace:*",
    "@plane/services": "workspace:*",
    "@plane/types": "workspace:*",
    "@plane/utils": "workspace:*",
    "lodash-es": "catalog:",
    "mobx": "catalog:",
    "mobx-utils": "catalog:",
    "uuid": "catalog:",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@plane/typescript-config": "workspace:*",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
