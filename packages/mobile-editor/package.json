{
  "name": "@plane/mobile-editor",
  "version": "2.3.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint-mobile": "eslint .",
    "preview": "vite preview",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules && rm -rf dist",
    "check:lint-mobile": "eslint . --cache --cache-location node_modules/.cache/eslint/ --max-warnings=0",
    "check:types-mobile": "tsc --noEmit",
    "check:format-mobile": "oxfmt . --check",
    "fix:lint-mobile": "eslint . --cache --cache-location node_modules/.cache/eslint/ --fix --max-warnings=0",
    "fix:format-mobile": "oxfmt . --write"
  },
  "dependencies": {
    "@plane/constants": "workspace:*",
    "@plane/editor": "workspace:*",
    "@plane/propel": "workspace:*",
    "@plane/ui": "workspace:*",
    "@plane/utils": "workspace:*",
    "lodash-es": "catalog:",
    "lucide-react": "catalog:",
    "mobx": "catalog:",
    "mobx-react": "catalog:",
    "mobx-utils": "catalog:",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@plane/tailwind-config": "workspace:*",
    "@plane/types": "workspace:*",
    "@plane/typescript-config": "workspace:*",
    "@tailwindcss/typography": "catalog:",
    "@types/lodash-es": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-node-polyfills": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  }
}
