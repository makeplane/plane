{
  "name": "@plane/mobile-editor",
  "version": "2.3.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint-mobile": "oxlint --type-aware -c ../../.oxlintrc.json .",
    "preview": "vite preview",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules && rm -rf dist",
    "check:lint-mobile": "oxlint --type-aware -c ../../.oxlintrc.json .",
    "check:types-mobile": "tsc --noEmit",
    "check:format-mobile": "oxfmt . --check",
    "fix:lint-mobile": "oxlint --type-aware --fix -c ../../.oxlintrc.json .",
    "fix:format-mobile": "oxfmt . --write"
  },
  "dependencies": {
    "@plane/constants": "workspace:*",
    "@plane/editor": "workspace:*",
    "@plane/propel": "workspace:*",
    "@plane/ui": "workspace:*",
    "@plane/utils": "workspace:*",
    "lodash-es": "catalog:",
    "lucide-react": "catalog:",
    "mobx": "catalog:",
    "mobx-react": "catalog:",
    "mobx-utils": "catalog:",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@plane/tailwindcss": "workspace:*",
    "@plane/types": "workspace:*",
    "@plane/typescript-config": "workspace:*",
    "@tailwindcss/typography": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/lodash-es": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  }
}
