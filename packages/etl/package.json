{
  "name": "@plane/etl",
  "version": "2.3.0",
  "private": true,
  "license": "AGPL",
  "author": "Plane Engineering",
  "repository": "https://github.com/makeplane/plane-ee",
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "exports": {
    "./asana": "./dist/asana/index.js",
    "./bitbucket": "./dist/bitbucket/index.js",
    "./clickup": "./dist/clickup/index.js",
    "./confluence": "./dist/confluence/index.js",
    "./core": "./dist/core/index.js",
    "./flatfile": "./dist/flatfile/index.js",
    "./github": "./dist/github/index.js",
    "./gitlab": "./dist/gitlab/index.js",
    "./jira": "./dist/jira/index.js",
    "./jira-server": "./dist/jira-server/index.js",
    "./linear": "./dist/linear/index.js",
    "./sentry": "./dist/sentry/index.js",
    "./slack": "./dist/slack/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules && rm -rf dist",
    "check:lint": "oxlint --type-aware -c ../../.oxlintrc.json .",
    "check:types": "tsc --noEmit",
    "check:format": "oxfmt . --check",
    "fix:lint": "oxlint --type-aware --fix -c ../../.oxlintrc.json .",
    "fix:format": "oxfmt . --write",
    "test": "vitest run"
  },
  "dependencies": {
    "@flatfile/api": "catalog:",
    "@linear/sdk": "^37.0.0",
    "@octokit/auth-app": "catalog:",
    "@octokit/rest": "catalog:",
    "@plane/constants": "workspace:*",
    "@plane/editor": "workspace:*",
    "@plane/sdk": "workspace:*",
    "@plane/types": "workspace:*",
    "@tiptap/core": "catalog:",
    "@tiptap/html": "catalog:",
    "asana": "catalog:",
    "axios": "catalog:",
    "jira.js": "catalog:",
    "node-html-parser": "catalog:",
    "papaparse": "catalog:",
    "uuid": "catalog:",
    "zeed-dom": "^0.15.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@octokit/openapi-webhooks-types": "catalog:",
    "@plane/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/papaparse": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@octokit/openapi-webhooks-types": ">=8",
    "react": ">=18"
  }
}
