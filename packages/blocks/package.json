{
  "name": "@plane/blocks",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "types": "./dist/utils/index.d.ts",
  "imports": {
    "#*": [
      "./*",
      "./*.ts",
      "./*.tsx",
      "./*.js",
      "./*.jsx"
    ]
  },
  "exports": {
    "./activity": "./dist/activity/index.js",
    "./common": "./dist/common/index.js",
    "./entity-detail": "./dist/entity-detail/index.js",
    "./utils": "./dist/utils/index.js",
    "./package.json": "./package.json",
    ".": {
      "style": "./dist/styles/index.css"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "check:lint": "oxlint --type-aware -c ../../.oxlintrc.json .",
    "check:types": "tsc --noEmit",
    "check:format": "oxfmt . --check",
    "fix:lint": "oxlint --type-aware --fix -c ../../.oxlintrc.json .",
    "fix:format": "oxfmt . --write",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules && rm -rf dist",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@plane/constants": "workspace:*",
    "@plane/hooks": "workspace:*",
    "@plane/propel": "workspace:*",
    "@plane/types": "workspace:*",
    "@plane/utils": "workspace:*",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@plane/tailwindcss": "workspace:*",
    "@plane/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-designs": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-themes": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "storybook": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
