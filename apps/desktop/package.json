{
  "name": "desktop",
  "version": "0.1.0",
  "description": "Plane desktop application for project management",
  "homepage": "https://plane.so",
  "license": "AGPL-3.0",
  "author": "Plane <support@plane.so>",
  "main": "./dist/main.js",
  "exports": {
    "./preload": "./dist/preload.js",
    "./tab-bar-preload": "./dist/tab-bar-preload.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdown --watch --onSuccess 'cp src/setup.html src/tab-bar.html dist/ && electron .'",
    "build": "tsdown && cp src/setup.html src/tab-bar.html dist/",
    "start": "pnpm build && electron ."
  },
  "dependencies": {
    "@todesktop/runtime": "catalog:",
    "electron-store": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "conf": "catalog:",
    "electron": "catalog:",
    "tsdown": "catalog:",
    "type-fest": "catalog:",
    "typescript": "catalog:"
  },
  "productName": "Plane"
}
