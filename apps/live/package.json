{
  "name": "live",
  "version": "2.3.0",
  "private": true,
  "description": "A realtime collaborative server powers Plane's rich text editor",
  "license": "AGPL-3.0",
  "author": "Plane Software Inc.",
  "type": "module",
  "main": "./dist/start.mjs",
  "module": "./dist/start.mjs",
  "exports": {
    ".": "./dist/start.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --onSuccess \"node --env-file=.env .\"",
    "start": "node --env-file=.env .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:lint": "oxlint --type-aware -c ../../.oxlintrc.json .",
    "check:types": "tsc --noEmit",
    "check:format": "oxfmt . --check",
    "fix:lint": "oxlint --type-aware --fix -c ../../.oxlintrc.json .",
    "fix:format": "oxfmt . --write",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules && rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "@fontsource/inter": "catalog:",
    "@hocuspocus/extension-database": "catalog:",
    "@hocuspocus/extension-logger": "catalog:",
    "@hocuspocus/extension-redis": "catalog:",
    "@hocuspocus/server": "catalog:",
    "@hocuspocus/transformer": "catalog:",
    "@hungknguyen/docx-math-converter": "catalog:",
    "@plane/constants": "workspace:*",
    "@plane/decorators": "workspace:*",
    "@plane/editor": "workspace:*",
    "@plane/logger": "workspace:*",
    "@plane/types": "workspace:*",
    "@react-pdf/renderer": "catalog:",
    "@react-pdf/types": "catalog:",
    "@sentry/node": "catalog:",
    "@sentry/profiling-node": "catalog:",
    "@tiptap/core": "catalog:",
    "@tiptap/html": "catalog:",
    "axios": "catalog:",
    "compression": "catalog:",
    "cookie-parser": "catalog:",
    "cors": "catalog:",
    "docx": "catalog:",
    "dotenv": "catalog:",
    "effect": "catalog:",
    "emoji-datasource-google": "catalog:",
    "express": "catalog:",
    "express-ws": "catalog:",
    "hast-util-to-mdast": "catalog:",
    "helmet": "catalog:",
    "ioredis": "catalog:",
    "jszip": "catalog:",
    "react": "catalog:",
    "rehype-parse": "catalog:",
    "rehype-remark": "catalog:",
    "remark-gfm": "catalog:",
    "remark-stringify": "catalog:",
    "sharp": "catalog:",
    "unified": "catalog:",
    "uuid": "catalog:",
    "ws": "catalog:",
    "y-prosemirror": "catalog:",
    "y-protocols": "catalog:",
    "yjs": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@plane/typescript-config": "workspace:*",
    "@types/compression": "catalog:",
    "@types/cookie-parser": "catalog:",
    "@types/cors": "catalog:",
    "@types/express": "catalog:",
    "@types/express-ws": "catalog:",
    "@types/hast": "catalog:",
    "@types/mdast": "catalog:",
    "@types/node": "catalog:",
    "@types/pdf-parse": "catalog:",
    "@types/react": "catalog:",
    "@types/uuid": "catalog:",
    "@types/ws": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "pdf-parse": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
