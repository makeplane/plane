# --- App ---
APP_VERSION="1.0.0"
NODE_ENV="production"
HOSTNAME=
PORT=3100
API_BASE_URL="http://localhost:8000"

WEB_BASE_URL="http://localhost:3000"

LIVE_BASE_URL="http://localhost:3100"
LIVE_BASE_PATH="/live"

LIVE_SERVER_SECRET_KEY="secret-key"

# --- CORS ---
# Comma-separated list of allowed origins; empty string disables CORS whitelist.
CORS_ALLOWED_ORIGINS=""

# --- Compression ---
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=5000

# --- Redis ---
# If you prefer not to provide a Redis URL, you can set the REDIS_HOST and REDIS_PORT environment variables instead.
# REDIS_URL can also be a bare host:port (e.g. master.xxx.use1.cache.amazonaws.com:6379)
# when ELASTICACHE_SECRET_ARN is set; the token is fetched from Secrets Manager automatically.
REDIS_URL=redis://localhost:6379/
REDIS_HOST=
REDIS_PORT=6379

# --- AWS Secrets Manager (ElastiCache auth via IAM) ---
ELASTICACHE_SECRET_ARN=
AWS_ROLE_ARN=
AWS_REGION="us-east-1"
REDIS_AUTH_TOKEN_KEY=
REDIS_HOST_KEY=
REDIS_PORT_KEY=
AWS_SECRET_CACHE_TTL=300
# EKS Pod Identity alternative to AWS_ROLE_ARN
AWS_CONTAINER_CREDENTIALS_FULL_URI=

# --- Iframely ---
IFRAMELY_URL=

# --- PDF export tuning (bump on CPU-throttled pods) ---
PDF_EXPORT_RENDER_TIMEOUT_MS=60000
PDF_EXPORT_KEEPALIVE_INTERVAL_MS=15000

# --- Links in exports ---
# Fallback used when WEB_BASE_URL is empty
APP_BASE_URL=

# --- Sentry ---
SENTRY_DSN=
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE=0.5

# --- RabbitMQ ---
AMQP_URL=amqp://plane:plane@localhost:5672/plane
