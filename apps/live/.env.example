PORT=3100
# Uses APP_HOST from root .env — must be set before Docker build
API_BASE_URL="${APP_HOST}/api"

WEB_BASE_URL="${APP_HOST}"

LIVE_BASE_URL="${APP_HOST}"
LIVE_BASE_PATH="/live"

LIVE_SERVER_SECRET_KEY="secret-key"

# If you prefer not to provide a Redis URL, you can set the REDIS_HOST and REDIS_PORT environment variables instead.
REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_URL="redis://localhost:6379/"
