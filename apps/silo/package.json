{
  "name": "silo",
  "version": "2.3.0",
  "private": true,
  "description": "A simple, lightweight, and fast integrations engine.",
  "author": "engineering@plane.so",
  "type": "module",
  "main": "./dist/start.mjs",
  "module": "./dist/start.mjs",
  "types": "./dist/start.d.mts",
  "exports": {
    ".": "./dist/start.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --onSuccess \"node --env-file=.env .\"",
    "start": "node --env-file=.env .",
    "test": "jest",
    "clean": "rm -rf .turbo && rm -rf .next && rm -rf node_modules && rm -rf dist",
    "check:lint": "eslint . --cache --cache-location node_modules/.cache/eslint/ --max-warnings=2553",
    "check:types": "tsc --noEmit",
    "check:format": "oxfmt . --check",
    "fix:lint": "eslint . --cache --cache-location node_modules/.cache/eslint/ --max-warnings=2553 --fix",
    "fix:format": "oxfmt . --write",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject ./dist && sentry-cli sourcemaps upload --release=$SENTRY_RELEASE_VERSION ./dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.989.0",
    "@aws-sdk/client-secrets-manager": "^3.989.0",
    "@aws-sdk/s3-request-presigner": "^3.989.0",
    "@dotenvx/dotenvx": "^1.52.0",
    "@flatfile/api": "^1.12.0",
    "@flatfile/listener": "^1.1.1",
    "@flatfile/plugin-record-hook": "^1.11.2",
    "@linear/sdk": "^30.0.0",
    "@makeplane/plane-node-sdk": "0.2.8",
    "@octokit/openapi-webhooks-types": "^8.3.0",
    "@plane/constants": "workspace:*",
    "@plane/decorators": "workspace:*",
    "@plane/etl": "workspace:*",
    "@plane/logger": "workspace:*",
    "@plane/sdk": "workspace:*",
    "@plane/types": "workspace:*",
    "@sentry/cli": "catalog:",
    "@sentry/core": "catalog:",
    "@sentry/node": "catalog:",
    "@sentry/profiling-node": "catalog:",
    "@slack/bolt": "^4.4.0",
    "@types/bluebird": "catalog:",
    "@types/cookie-parser": "catalog:",
    "@types/jest": "catalog:",
    "@types/pg": "catalog:",
    "@types/turndown": "catalog:",
    "amqplib": "0.10.5",
    "axios": "catalog:",
    "bluebird": "^3.7.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dd-trace": "^5.45.0",
    "express": "4.22.0",
    "express-winston": "^4.2.0",
    "jira.js": "^4.0.1",
    "marked": "^15.0.4",
    "mimetics": "^1.0.4",
    "node-html-parser": "^6.1.13",
    "pg": "^8.15.5",
    "postgres": "^3.4.4",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.6",
    "turndown": "^7.2.0",
    "type-fest": "^4.26.1",
    "uuid": "^11.0.3",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@plane/typescript-config": "workspace:*",
    "@slack/types": "^2.20.0",
    "@t3-oss/env-core": "^0.11.1",
    "@types/adm-zip": "catalog:",
    "@types/amqplib": "catalog:",
    "@types/cors": "catalog:",
    "@types/express": "catalog:",
    "@types/jest": "catalog:",
    "adm-zip": "^0.5.16",
    "jest": "^30.0.5",
    "node-html-parser": "^6.1.13",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
