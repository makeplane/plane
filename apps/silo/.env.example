# App Environment Variables
BATCH_SIZE=100
PORT=3000
MQ_PREFETCH_COUNT=5
APP_BASE_URL=http://web:3000
SILO_API_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"
AES_SECRET_KEY="plane-testing-key"
# Database Settings
POSTGRES_USER="plane"
POSTGRES_PASSWORD="plane"
POSTGRES_HOST="localhost"
POSTGRES_DB="plane"
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# RabbitMQ Environment Variables
RABBITMQ_HOST="localhost"
RABBITMQ_PORT="5672"
RABBITMQ_USER="plane"
RABBITMQ_PASSWORD="plane"
RABBITMQ_VHOST="plane"
AMQP_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/${RABBITMQ_VHOST}
# AWS Secrets Manager (optional - for ElastiCache / AmazonMQ on AWS)
# Supports both IRSA (AWS_ROLE_ARN) and EKS Pod Identity (AWS_CONTAINER_CREDENTIALS_FULL_URI)
# AWS_ROLE_ARN=arn:aws:iam::123456789:role/my-role
# AWS_CONTAINER_CREDENTIALS_FULL_URI=http://169.254.170.23/v1/credentials
# AWS_SECRET_CACHE_TTL=300
# ElastiCache: set REDIS_URL to a bare host:port OR leave unset and set ELASTICACHE_SECRET_ARN
# ELASTICACHE_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret/my-redis-secret
# REDIS_AUTH_TOKEN_KEY=token
# AmazonMQ: set AMQP_URL to a bare host:port OR leave unset and set AMAZONMQ_SECRET_ARN
# AMAZONMQ_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret/my-mq-secret
# RABBITMQ_USER_KEY=username
# RABBITMQ_PASSWORD_KEY=password

# Redis Environment Variables
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/

# Sentry Environment Variables
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# integrations
# Jira Environment Variables
JIRA_CLIENT_ID=your_jira_client_id
JIRA_CLIENT_SECRET=your_jira_client_secret

# Linear Environment Variables
LINEAR_CLIENT_ID=your_linear_client_id
LINEAR_CLIENT_SECRET=your_linear_client_secret

# Github Environment Variables
GITHUB_AUTHORIZATION_URL=https://github.com/login/oauth/authorize
GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_CALLBACK_URL=http://localhost:8080/silo/api/github/auth/callback
GITHUB_APP_NAME=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=

# Gitlab Environment Variables
GITLAB_CLIENT_ID=your_gitlab_client_id
GITLAB_CLIENT_SECRET=your_gitlab_client_secret

# Asana Environment Variables
ASANA_CLIENT_ID=your_asana_client_id
ASANA_CLIENT_SECRET=your_asana_client_secret
# Slack Environment Variables
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
