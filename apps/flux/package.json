{
  "name": "flux",
  "version": "2.3.0",
  "private": true,
  "description": "WebSocket flux service for horizontal scaling with Redis pub/sub",
  "license": "AGPL-3.0",
  "author": "Plane Software Inc.",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs",
    "./consumer": "./dist/consumer.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --onSuccess \"node --env-file=.env .\"",
    "dev:consumer": "tsdown --watch --onSuccess \"node --env-file=.env ./dist/consumer.mjs\"",
    "start": "node --env-file=.env .",
    "check:lint": "oxlint --type-aware -c ../../.oxlintrc.json .",
    "check:types": "tsc --noEmit",
    "check:format": "oxfmt . --check",
    "fix:lint": "oxlint --type-aware --fix -c ../../.oxlintrc.json .",
    "fix:format": "oxfmt . --write",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "dependencies": {
    "@effect/opentelemetry": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/context-async-hooks": "catalog:",
    "@opentelemetry/core": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-logs": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/sdk-trace-node": "catalog:",
    "@opentelemetry/sdk-trace-web": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "@sentry/node": "catalog:",
    "@sentry/opentelemetry": "catalog:",
    "@socket.io/redis-adapter": "catalog:",
    "@socket.io/redis-emitter": "catalog:",
    "amqplib": "catalog:",
    "dd-trace": "catalog:",
    "effect": "catalog:",
    "ioredis": "catalog:",
    "socket.io": "catalog:"
  },
  "devDependencies": {
    "@plane/typescript-config": "workspace:*",
    "@types/amqplib": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
