# -------------------------------
# Debug & Development
# -------------------------------
LOG_LEVEL=DEBUG
DEV_WORKSPACE_ID=

# -------------------------------
# FastAPI Configuration
# -------------------------------
FASTAPI_APP_HOST=0.0.0.0
FASTAPI_APP_PORT=8000
FASTAPI_APP_WORKERS=1
PI_BASE_PATH=/pi

# -------------------------------
# Sentry for error monitoring
# -------------------------------
SENTRY_DSN=https://...
SENTRY_ENVIRONMENT=

# -------------------------------
# CORS (Allowed frontend origins)
# -------------------------------
CORS_ALLOWED_ORIGINS='http://127.0.0.1:3000, http://localhost:3000, http://localhost:8000, http://127.0.0.1:8000, https://local.plane.so, https://pi-runway.plane.tools'

# -------------------------------
# Datadog (optional monitoring)
# -------------------------------
DD_ENABLED=1
DD_ENV=dev
DD_SERVICE=plane-pi-api
DD_AGENT_HOST=
DD_TRACE_SAMPLE_RATE=0

# -------------------------------
# Plane API
# -------------------------------
PLANE_API_HOST=https://api.plane.so
# PLANE_INTERNAL_API_HOST: Internal base URL for PI to reach the Plane API (e.g., service DNS in Docker/K8s)
# If not set, falls back to PLANE_API_HOST. Use this to avoid routing issues in private networks.
# PLANE_INTERNAL_API_HOST=http://api:8000
PLANE_FRONTEND_URL=https://app.plane.so
SESSION_COOKIE_NAME=session-id

# -------------------------------
# Database Configuration
# -------------------------------
# Plane follower database URL
FOLLOWER_POSTGRES_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# AWS Secrets Manager — alternative to FOLLOWER_POSTGRES_URI (requires IRSA or EKS Pod Identity)
# FOLLOWER_RDS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:plane/follower-rds-xxxx
# FOLLOWER_RDS_DB_HOST_KEY=host
# FOLLOWER_RDS_DB_PORT_KEY=port
# FOLLOWER_RDS_DB_USERNAME_KEY=username
# FOLLOWER_RDS_DB_PASSWORD_KEY=password
# FOLLOWER_RDS_DB_NAME_KEY=dbname

# Plane PI primary database
PLANE_PI_POSTGRES_USER=plane-pi
PLANE_PI_POSTGRES_PASSWORD=plane-pi
PLANE_PI_POSTGRES_HOST=localhost
PLANE_PI_POSTGRES_PORT=5432
PLANE_PI_POSTGRES_DB=plane-pi
PLANE_PI_DATABASE_URL=postgresql://${PLANE_PI_POSTGRES_USER}:${PLANE_PI_POSTGRES_PASSWORD}@${PLANE_PI_POSTGRES_HOST}:${PLANE_PI_POSTGRES_PORT}/${PLANE_PI_POSTGRES_DB}

# AWS Secrets Manager — alternative to PLANE_PI_DATABASE_URL (requires IRSA or EKS Pod Identity)
# RDS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:plane/rds-xxxx
# RDS_DB_HOST_KEY=host
# RDS_DB_PORT_KEY=port
# RDS_DB_USERNAME_KEY=username
# RDS_DB_PASSWORD_KEY=password
# RDS_DB_NAME_KEY=dbname

# -------------------------------
# API Keys (for AI/LLM Providers)
# -------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# AWS Secrets Manager — alternative to individual API keys (requires IRSA or EKS Pod Identity)
# MODEL_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:plane/model-keys-xxxx
# MODEL_OPENAI_KEY=openai_api_key
# MODEL_CLAUDE_KEY=claude_api_key
# MODEL_GROQ_KEY=groq_api_key
# MODEL_COHERE_KEY=cohere_api_key
# MODEL_CUSTOM_LLM_API_KEY=custom_llm_api_key

# Optional
OPENAI_BASE_URL=
CLAUDE_BASE_URL=
COHERE_BASE_URL=
GROQ_BASE_URL=

# Custom LLM Configuration
CUSTOM_LLM_ENABLED=true
CUSTOM_LLM_MODEL_KEY=lfm2.5-thinking
CUSTOM_LLM_BASE_URL=https://api.groq.com/openai/v1
CUSTOM_LLM_API_KEY=gsk_xxxx
CUSTOM_LLM_NAME=GPT-OSS-120B
CUSTOM_LLM_MAX_TOKENS=128000
CUSTOM_LLM_PROVIDER=
CUSTOM_LLM_AWS_REGION=

# AWS Bedrock Inference Profile (requires IRSA or EKS Pod Identity — no API key needed)
# Use when routing Bedrock calls via a cross-region inference profile ARN.
# CUSTOM_LLM_AWS_REGION must match the region in the ARN.
# BEDROCK_INFERENCE_PROFILE_ARN=arn:aws:bedrock:us-east-1:123456789012:application-inference-profile/xxxx
# BEDROCK_INFERENCE_PROFILE_ID=global.anthropic.claude-sonnet-4-6

# -------------------------------
# OpenSearch
# -------------------------------
# One-time triggers to feed data from the database into the OpenSearch index.
# Used only for initial indexing (not for live sync).
# If DEV_WORKSPACE_ID is set, only that workspace’s data is indexed; otherwise, all workspaces are indexed.
FEED_ISSUES_DATA=0
FEED_PAGES_DATA=0
FEED_DOCS_DATA=0
FEED_SLICES=0

# Batch and scroll settings for indexing
BATCH_SIZE=64
SCROLL_TIMEOUT=10m

# Index prefix (Optional)
OPENSEARCH_INDEX_PREFIX=

# OpenSearch credentials
OPENSEARCH_URL=xxx
OPENSEARCH_USERNAME=xxx
OPENSEARCH_PASSWORD=xxx
# AWS IAM SigV4 — alternative to OPENSEARCH_USERNAME/OPENSEARCH_PASSWORD
# When running on EKS with pod identity or IRSA, leave username/password empty
# and ensure AWS_REGION is set. PI will sign OpenSearch requests with SigV4 automatically.

# Embedding model ID (for semantic search)
OPENSEARCH_ML_MODEL_ID=xxx
OPENSEARCH_EMBEDDING_DIMENSION=1536
EMBEDDING_MODEL=cohere/embed-v4.0

# -------------------------------
# AWS S3 / MinIO Storage Configuration
# -------------------------------
# Leave empty when using IRSA or EKS Pod Identity; boto3 will use the default credential chain
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_S3_BUCKET_NAME=xxx
AWS_S3_ENV=xxx
AWS_REGION=xxx

# MinIO Configuration
# USE_MINIO: Set to 1 when using MinIO instead of AWS S3
#   - When 1: presigned URLs use the request's public hostname (e.g., app.plane.so)
#   - When 0: uses standard AWS S3 endpoints
USE_MINIO=0

# AWS_S3_ENDPOINT_URL: Internal endpoint for server operations (uploads)
#   - Leave empty for AWS S3 (uses default AWS endpoints)
#   - For MinIO: (internal k8s)
#   - This is used for server-side uploads, not for browser-accessible URLs
AWS_S3_ENDPOINT_URL=

# -------------------------------
# AWS Bedrock Configuration (for Embeddings)
# -------------------------------
# Separate credentials for AWS Bedrock embedding models (used by OpenSearch ML connector).
# If not set, will fall back to AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY.
# For pod identity (IRSA/EKS Pod Identity): leave all BR_AWS_* empty and ensure the pod has
# bedrock:InvokeModel (and optionally bedrock:InvokeModelWithResponseStream) permissions.
# Note: OpenSearch connector may still require explicit credentials; S3 and Secrets Manager use default chain when keys are unset.
BR_AWS_ACCESS_KEY_ID=
BR_AWS_SECRET_ACCESS_KEY=
BR_AWS_SESSION_TOKEN=
BR_AWS_REGION=us-east-1

# -------------------------------
# Celery & RabbitMQ (for background tasks)
# -------------------------------
# Task intervals (in seconds)
CELERY_VECTOR_SYNC_INTERVAL=3
CELERY_VECTOR_SYNC_ENABLED=1
CELERY_WORKSPACE_PLAN_SYNC_ENABLED=1
CELERY_WORKSPACE_PLAN_SYNC_INTERVAL=86400
CELERY_PI_MESSAGES_INDEX_SYNC_ENABLED=0
CELERY_DOCS_SYNC_ENABLED=1
CELERY_DOCS_SYNC_INTERVAL=86400

# RabbitMQ credentials
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_VHOST=/

# Celery broker
AMQP_URL=pyamqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672//

# AWS Secrets Manager — alternative to AMQP_URL (requires IRSA or EKS Pod Identity)
# AMAZONMQ_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:plane/amazonmq-xxxx
# RABBITMQ_USER_KEY=username
# RABBITMQ_PASSWORD_KEY=password
# RABBITMQ_HOST_KEY=host
# RABBITMQ_PORT_KEY=port
# RABBITMQ_VHOST_KEY=vhost
#
# AWS Secrets Manager — inject creds into a host-only AMQP_URL
# If you set AMQP_URL without embedded credentials (e.g. just `host:5671`), PI will fetch
# username/password from AMAZONMQ_SECRET_ARN and construct a full broker URL.
# AMQP_URL=b-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.mq.us-east-1.on.aws:5671

# -------------------------------
# Feature Flags
# -------------------------------
FEATURE_FLAG_SERVER_BASE_URL="https://preview.disco.plane.town"
FEATURE_FLAG_SERVER_AUTH_TOKEN="xxxxxxxxxxxx"

# -------------------------------
# PI Integration App (OAuth Credentials)
# -------------------------------
PLANE_OAUTH_REDIRECT_URI=https://plane-pi.plane.so/api/v1/oauth/callback/
PLANE_OAUTH_STATE_EXPIRY_SECONDS=82800
PLANE_OAUTH_URL_ENCRYPTION_KEY=
AES_SECRET_KEY=
AES_SALT=