# Schema for /root/plane.env (referenced by deploy/docker-compose.yaml).
# Copy this file to /root/plane.env and fill in real values. NEVER commit
# the populated copy.

# Domain / proxy
APP_DOMAIN=plane.example.com
WEB_URL=https://plane.example.com
SITE_ADDRESS=plane.example.com
CORS_ALLOWED_ORIGINS=https://plane.example.com
APP_RELEASE=stable
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443
TRUSTED_PROXIES=
CERT_EMAIL=
CERT_ACME_CA=
CERT_ACME_DNS=

# Replicas
WEB_REPLICAS=1
SPACE_REPLICAS=1
ADMIN_REPLICAS=1
API_REPLICAS=1
WORKER_REPLICAS=1
BEAT_WORKER_REPLICAS=1
LIVE_REPLICAS=1

# App
DEBUG=0
SECRET_KEY=replace-me-with-random-50-char-string
LIVE_SERVER_SECRET_KEY=replace-me
API_BASE_URL=http://api:8000
GUNICORN_WORKERS=1
API_KEY_RATE_LIMIT=60/minute
FILE_SIZE_LIMIT=5242880

# Postgres
PGHOST=plane-db
PGDATABASE=plane
POSTGRES_USER=plane
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=plane
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data
DATABASE_URL=postgresql://plane:replace-me@plane-db/plane

# Redis
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379/

# RabbitMQ
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=replace-me
RABBITMQ_VHOST=plane
AMQP_URL=amqp://plane:replace-me@plane-mq:5672/plane

# Object storage (MinIO by default)
USE_MINIO=1
MINIO_ENDPOINT_SSL=0
AWS_REGION=
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
