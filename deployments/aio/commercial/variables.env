DOMAIN_NAME=localhost
APP_RELEASE_VERSION=v1.14.0
IS_AIRGAPPED=0

APP_PROTOCOL=http
API_HOSTNAME=http://localhost:3004

# If SSL Cert to be generated, set CERT_EMAIL and APP_PROTOCOL to https
